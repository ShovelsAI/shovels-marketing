{
  "name": "shovels-marketing",
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/line-clamp": "^0.4.4",
    "tailwindcss": "^3.4.17"
  },
  "scripts": {
    "dev": "trap 'kill 0' EXIT INT TERM; tailwindcss -i ./themes/shovels/static/css/input.css -o ./themes/shovels/static/css/output.css --watch & uv run pelican -lr content -o output -s pelicanconf.py -p 8000",
    "build:css": "tailwindcss -i ./themes/shovels/static/css/input.css -o ./themes/shovels/static/css/output.css --watch",
    "build:css:prod": "tailwindcss -i ./themes/shovels/static/css/input.css -o ./themes/shovels/static/css/output.css --minify",
    "prepare": "git config core.hooksPath .githooks || true"
  }
}
